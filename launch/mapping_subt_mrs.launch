<launch>
<!-- Launch file for SubT_MRS dataset-->

	<arg name="rviz" default="true" />

	<rosparam command="load" file="$(find voxel_pillar)/config/SubT_MRS.yaml" />
	<node pkg="voxel_pillar" type="fastlivo_mapping" name="laserMapping" output="screen">
		<rosparam file="$(find voxel_pillar)/config/camera_pinhole_SubT_MRS.yaml" />
	</node>

	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find voxel_pillar)/rviz_cfg/voxel_pillar.rviz" />
	</group>

    

launch-prefix="gdb -ex run --args"
launch-prefix="valgrind --leak-check=full"
</launch> 	
