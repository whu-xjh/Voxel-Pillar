<launch>

	<arg name="rviz" default="true" />

	<rosparam command="load" file="$(find voxel_pillar)/config/HILTI22.yaml" />

	<node pkg="voxel_pillar" type="fastlivo_mapping" name="laserMapping" output="screen">
		<rosparam file="$(find voxel_pillar)/config/camera_fisheye_HILTI22.yaml" />
	</node>
	
	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find voxel_pillar)/rviz_cfg/hilti.rviz" />
	</group>

launch-prefix="gdb -ex run --args"
launch-prefix="valgrind --leak-check=full"

</launch> 	
