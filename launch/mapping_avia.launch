<launch>
<!-- Launch file for Livox AVIA LiDAR -->

	<arg name="rviz" default="true" />

	<!-- LiDAR topic merger node -->
	<node pkg="voxel_pillar" type="merge_lidar" name="merge_lidar" output="screen">
		<param name="output_topic" value="/livox/multi_lidar" />
		<param name="input_topic_159" value="/livox/lidar_192_168_1_159" />
		<param name="input_topic_160" value="/livox/lidar_192_168_1_160" />
		<param name="input_topic_161" value="/livox/lidar_192_168_1_161" />
	</node>

	<rosparam command="load" file="$(find voxel_pillar)/config/avia.yaml" />

	<node pkg="voxel_pillar" type="voxelpillar_mapping" name="laserMapping" output="screen">
		<rosparam file="$(find voxel_pillar)/config/camera_pinhole.yaml" />
	</node>

	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find voxel_pillar)/rviz_cfg/voxel_pillar.rviz" />
	</group>

	<node pkg="image_transport" type="republish" name="republish" args="compressed in:=/left_camera/image raw out:=/left_camera/image" output="screen" respawn="true"/>

launch-prefix="gdb -ex run --args"
launch-prefix="valgrind --leak-check=full"
</launch>
